{
  "name": "@hawkeye/cli",
  "version": "0.1.0",
  "description": "Hawkeye CLI - command-line interface to the Hawkeye Core engine",
  "type": "module",
  "private": false,
  "bin": {
    "hawkeye": "./dist/main.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hawkeye/core": "workspace:*",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
